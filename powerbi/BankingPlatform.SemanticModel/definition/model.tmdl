model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	annotation PBI_QueryOrder = ["DimDate","DimCustomer","DimAccount","DimProduct","DimBranch","FactTransaction","FactLoanBalance","AggDailyDeposits","AggMonthlyLoans","AggMonthlyDeposits","AggDelinquencyRoll"]
	annotation __PBI_TimeIntelligenceEnabled = 0