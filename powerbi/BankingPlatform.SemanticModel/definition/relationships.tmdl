relationship Txn_Date
	fromColumn: FactTransaction.DateKey
	toColumn: DimDate.DateKey

relationship Txn_Account
	fromColumn: FactTransaction.AccountKey
	toColumn: DimAccount.AccountKey

relationship Txn_Customer
	fromColumn: FactTransaction.CustomerKey
	toColumn: DimCustomer.CustomerKey

relationship Txn_Product
	fromColumn: FactTransaction.ProductKey
	toColumn: DimProduct.ProductKey

relationship Txn_Branch
	fromColumn: FactTransaction.BranchKey
	toColumn: DimBranch.BranchKey

relationship Loan_Date
	fromColumn: FactLoanBalance.DateKey
	toColumn: DimDate.DateKey

relationship Loan_Account
	fromColumn: FactLoanBalance.AccountKey
	toColumn: DimAccount.AccountKey

relationship Loan_Customer
	fromColumn: FactLoanBalance.CustomerKey
	toColumn: DimCustomer.CustomerKey

relationship Loan_Product
	fromColumn: FactLoanBalance.ProductKey
	toColumn: DimProduct.ProductKey

relationship Loan_Branch
	fromColumn: FactLoanBalance.BranchKey
	toColumn: DimBranch.BranchKey

relationship Dep_Date
	fromColumn: AggDailyDeposits.DateKey
	toColumn: DimDate.DateKey

relationship Dep_Branch
	fromColumn: AggDailyDeposits.BranchKey
	toColumn: DimBranch.BranchKey

relationship Dep_Product
	fromColumn: AggDailyDeposits.ProductKey
	toColumn: DimProduct.ProductKey